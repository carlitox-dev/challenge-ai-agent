
# Configuración de variables de entorno para el proyecto
#
# - En LOCAL: completar las variables *_API_KEY con el valor directo, como
#   se muestra abajo.
# - En la instancia OCI: dejar las variables *_API_KEY vacías y en su lugar
#   completar las variables *_OCID con el OCID del secreto correspondiente
#   creado en OCI Vault (Identity & Security > Vault > Secrets). 
#   La aplicación resolverá el valor real en tiempo de ejecución usando
#   Instance Principals (ver app/secrets_manager.py).

# variables para Gemini
GEMINI_API_KEY=
GEMINI_API_KEY_OCID=ocid1.vaultsecret.oc1.sa-saopaulo-1.amaaaaaa25ukwoqafsuv2m4chogdkt53zi46blwrmfnhcra3lncrmp6hsfvq
GEMINI_MODEL='gemini-3.1-pro-preview'
GEMINI_EMBEDDING_MODEL='gemini-embedding-2-preview'

# variables para Groq
GROQ_API_KEY=
GROQ_API_KEY_OCID=ocid1.vaultsecret.oc1.sa-saopaulo-1.amaaaaaa25ukwoqamjgz6nteydk6owyg4oakzc6wivado6fbmv2ulmuqul7a
GROQ_MODEL='llama-3.3-70b-versatile'
GROQ_EMBEDDING_MODEL='groq-embedding-1'

# otras
CHUNK_SIZE=1000
